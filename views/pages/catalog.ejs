<section class="search-bar-wrapper">
    <div class="search-bar-container">
        <span class="search-icon"><%= section.charAt(0).toUpperCase() + section.slice(1) %></span>
        <input type="text" class="search-input" placeholder="<%= searchPlaceholder %>">
        <button class="search-btn-icon" type="button">Go</button>
    </div>
</section>

<div class="page-container <%= section %>-page">
    <h1 class="page-title"><%= heading %></h1>
    <% if (!items.length) { %>
        <div class="card">
            <div class="card-content">
                <p>No <%= section %> items are published yet.</p>
            </div>
        </div>
    <% } else { %>
        <div class="cards-grid">
            <% items.forEach((item) => { %>
                <div class="card">
                    <% if (item.image) { %>
                        <div class="card-image" style="background-image: url('<%= item.image %>');"></div>
                    <% } %>
                    <div class="card-content">
                        <h3><%= item.title %></h3>
                        <p><%= item.description %></p>
                        <% if (item.priceLabel) { %>
                            <div class="card-footer">
                                <span class="card-price"><%= formatPriceLabel(item.priceLabel) %></span>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>
</div>
