<section class="search-bar-wrapper">
    <div class="search-bar-container">
        <span class="search-icon">World</span>
        <input type="text" class="search-input" placeholder="Browse dynamic destination data from MongoDB...">
        <button class="search-btn-icon" type="button">Go</button>
    </div>
</section>

<div class="page-container destination-page">
    <h1 class="page-title">Explore Destinations</h1>

    <% if (currentUser && currentUser.role === 'admin') { %>
        <div class="card admin-card">
            <div class="card-content">
                <h3>Add Destination</h3>
                <form action="/destinations" method="POST">
                    <div class="content-grid compact-grid">
                        <div class="form-group">
                            <label for="destinationName">Name</label>
                            <input id="destinationName" type="text" name="name" required>
                        </div>
                        <div class="form-group">
                            <label for="destinationLocation">Location</label>
                            <input id="destinationLocation" type="text" name="location" required>
                        </div>
                        <div class="form-group">
                            <label for="destinationPrice">Price</label>
                            <input id="destinationPrice" type="number" min="0" name="price" required>
                        </div>
                        <div class="form-group">
                            <label for="destinationImage">Image URL</label>
                            <input id="destinationImage" type="url" name="image" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="destinationDescription">Description</label>
                        <textarea id="destinationDescription" name="description" required></textarea>
                    </div>
                    <button class="btn btn-primary" type="submit">Add Destination</button>
                </form>
            </div>
        </div>
    <% } %>

    <div class="cards-grid">
        <% destinations.forEach((destination) => { %>
            <div class="card">
                <div class="card-image" style="background-image: url('<%= destination.image %>');"></div>
                <div class="card-content">
                    <h3><%= destination.name %></h3>
                    <p><%= destination.description %></p>
                    <div class="card-footer">
                        <span class="card-price">$<%= destination.price %></span>
                        <a href="/destinations/<%= destination._id %>" class="card-button">View Details</a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
