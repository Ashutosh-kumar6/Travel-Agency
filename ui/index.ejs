<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travel Agency - Premium Travel Experience</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- ==================== NAVBAR ==================== -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">✈️ TRAVEL AGENCY</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/destination">Destinations</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/food">Food</a></li>
                <li><a href="/rental">Rentals</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/bookYourTrip">Book Your Trip</a></li>
            </ul>
            <div class="auth-buttons">
                <a href="/login" class="btn btn-secondary">Login</a>
                <a href="/register" class="btn btn-primary">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- ==================== SEARCH BAR ==================== -->
    <div class="search-bar-wrapper">
        <div class="search-bar-container">
            <span class="search-icon">🏠</span>
            <input type="text" class="search-input" placeholder="Explore destinations, services, or experiences...">
            <button class="search-btn-icon">🔍</button>
        </div>
    </div>

    <!-- ==================== HERO SECTION ==================== -->
    <section class="hero">
        <div class="hero-background"></div>
        <div class="hero-content">
            <h1>Discover Your Next Adventure</h1>
            <p>Experience the world's most exclusive destinations with world-class service and unforgettable moments</p>
            <div class="hero-buttons">
                <a href="/destination" class="btn btn-primary btn-large">Explore Destinations</a>
                <a href="/contact" class="btn btn-secondary btn-large">Get In Touch</a>
            </div>
        </div>
    </section>

    <!-- ==================== FEATURED DESTINATIONS ==================== -->
    <section class="featured">
        <h2 class="section-title">✨ Featured Destinations</h2>
        <div class="cards-grid">
            <div class="card fade-in">
                <div class="card-image">🏝️</div>
                <div class="card-content">
                    <h3>Maldives Paradise</h3>
                    <p>Pristine white-sand beaches, crystal-clear waters, and luxury overwater villas await you.</p>
                    <div class="card-footer">
                        <span class="card-price">From $2,999</span>
                        <button class="card-button">Explore</button>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-image">🗼</div>
                <div class="card-content">
                    <h3>Parisian Elegance</h3>
                    <p>The City of Light awaits with world-class art, cuisine, and timeless architecture.</p>
                    <div class="card-footer">
                        <span class="card-price">From $1,899</span>
                        <button class="card-button">Explore</button>
                    </div>
                </div>
            </div>

            <div class="card fade-in">
                <div class="card-image">🏔️</div>
                <div class="card-content">
                    <h3>Alpine Adventure</h3>
                    <p>Experience the majestic Swiss Alps with luxury chalets and breathtaking mountain views.</p>
                    <div class="card-footer">
                        <span class="card-price">From $2,499</span>
                        <button class="card-button">Explore</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== WHY CHOOSE US ==================== -->
    <section class="featured">
        <h2 class="section-title">🎯 Why Choose Travel Agency</h2>
        <div class="cards-grid">
            <div class="card">
                <div class="card-image">👑</div>
                <div class="card-content">
                    <h3>Premium Experience</h3>
                    <p>Handpicked luxury accommodations and exclusive experiences tailored to your preferences.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-image">🛡️</div>
                <div class="card-content">
                    <h3>Complete Protection</h3>
                    <p>24/7 travel insurance, emergency support, and peace of mind throughout your journey.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-image">💎</div>
                <div class="card-content">
                    <h3>Personalized Service</h3>
                    <p>Dedicated travel concierge ensures every detail is perfect for your dream vacation.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== FOOTER ==================== -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>About Us</h4>
                <p>Travel Agency brings you the finest travel experiences across the globe with premium service and unmatched expertise.</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/destination">Destinations</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/food">Cuisine</a></li>
                    <li><a href="/rental">Rentals</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <ul>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Terms & Conditions</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <ul>
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">Instagram</a></li>
                    <li><a href="#">Twitter</a></li>
                    <li><a href="#">LinkedIn</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Travel Agency. All rights reserved. | Crafted with ❤️ for luxury travelers</p>
        </div>
    </footer>
    <script src="/script.js"></script>
</body>
</html>