<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rentals - Travel Agency</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">✈️ TRAVEL AGENCY</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/destination">Destinations</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/food">Food</a></li>
                <li><a href="/rental">Rentals</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/bookYourTrip">Book Your Trip</a></li>
            </ul>
            <div class="auth-buttons">
                <a href="/login" class="btn btn-secondary">Login</a>
                <a href="/register" class="btn btn-primary">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- SEARCH BAR -->
    <div class="search-bar-wrapper">
        <div class="search-bar-container">
            <span class="search-icon">🚗</span>
            <input type="text" class="search-input" placeholder="Search vehicles, yachts, or private jets...">
            <button class="search-btn-icon">🔍</button>
        </div>
    </div>

    <!-- PAGE CONTENT -->
    <div class="page-container rental-page">
        <h1 class="page-title">🚗 Premium Vehicle Rentals</h1>
        
        <div class="cards-grid">
            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Luxury Sports Cars</h3>
                    <p>Ferrari, Lamborghini, and Porsche rentals in Monaco, Miami, and beyond.</p>
                    <div class="card-footer">
                        <span class="card-price">From $500/day</span>
                        <button class="card-button">Reserve</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1558618047-3c8c76ca7d13?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Premium SUVs</h3>
                    <p>Range Rover, G-Wagon, and other luxury SUVs with private driver options.</p>
                    <div class="card-footer">
                        <span class="card-price">From $300/day</span>
                        <button class="card-button">Reserve</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1558618047-3c8c76ca7d13?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Luxury Sedans</h3>
                    <p>Mercedes, BMW, and Rolls Royce with executive chauffeur services.</p>
                    <div class="card-footer">
                        <span class="card-price">From $200/day</span>
                        <button class="card-button">Reserve</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1544551763-46a013bb70d5?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Yacht Charters</h3>
                    <p>Private yachts ranging from 30ft to 200ft+ with full crew and catering.</p>
                    <div class="card-footer">
                        <span class="card-price">From $2000/day</span>
                        <button class="card-button">Reserve</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1544551763-46a013bb70d5?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Speed Boats</h3>
                    <p>High-performance boats for island hopping and water sports adventures.</p>
                    <div class="card-footer">
                        <span class="card-price">From $800/day</span>
                        <button class="card-button">Reserve</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Private Jets</h3>
                    <p>On-demand chartered flights for ultimate convenience and flexibility.</p>
                    <div class="card-footer">
                        <span class="card-price">From $5000/hr</span>
                        <button class="card-button">Reserve</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>About Us</h4>
                <p>Premier luxury transportation and rental services worldwide.</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/destination">Destinations</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/rental">Rentals</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <ul>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <ul>
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">Instagram</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Travel Agency. All rights reserved.</p>
        </div>
    </footer>
    <script src="/script.js"></script>
</body>
</html>
