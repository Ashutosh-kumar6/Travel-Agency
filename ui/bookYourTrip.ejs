<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Your Trip</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css">
    
</head>
<body>
    <%- include('navbar.ejs') %>

    <div class="booking-container">
        <!-- HEADER -->
        <div class="booking-header">
            <h1>✈️ Book Your Journey</h1>
            <p>Find and book the perfect travel experience</p>
        </div>

        <!-- SEARCH BOX -->
        <div class="search-section">
            <div class="search-box">
                <form id="searchForm" class="search-form">
                    <div class="search-row">
                        <div class="form-group">
                            <label for="from"><i class="ri-map-pin-line"></i> Leaving From</label>
                            <input type="text" id="from" placeholder="Enter departure city" required>
                        </div>

                        <div class="form-group">
                            <label for="to"><i class="ri-map-pin-line"></i> Going To</label>
                            <input type="text" id="to" placeholder="Enter destination city" required>
                        </div>

                        <div class="form-group">
                            <label for="departure"><i class="ri-calendar-line"></i> Departure</label>
                            <input type="date" id="departure" required>
                        </div>

                        <button type="button" class="swap-btn" title="Swap destinations">
                            <i class="ri-repeat-2-line"></i>
                        </button>

                        <button type="submit" class="search-btn">Search <i class="ri-arrow-right-line"></i></button>
                    </div>
                </form>
            </div>
        </div>

        <!-- MAIN CONTENT -->
        <div class="filters-results-container">
            <!-- FILTERS SIDEBAR -->
            <aside class="filters-sidebar">
                <!-- Bus Type Filter -->
                <div class="filter-section">
                    <h3>Bus Type <button class="clear-filters" onclick="clearFilters()">Clear All</button></h3>
                    <div class="bus-type-options">
                        <button class="type-btn" data-type="ac" onclick="filterByType(this)">
                            <i class="ri-temp-cold-line"></i> AC
                        </button>
                        <button class="type-btn" data-type="non-ac" onclick="filterByType(this)">
                            <i class="ri-temp-hot-line"></i> Non AC
                        </button>
                        <button class="type-btn" data-type="seater" onclick="filterByType(this)">
                            <i class="ri-sofa-line"></i> Seater
                        </button>
                        <button class="type-btn" data-type="sleeper" onclick="filterByType(this)">
                            <i class="ri-bed-line"></i> Sleeper
                        </button>
                    </div>
                </div>

                <!-- Price Filter -->
                <div class="filter-section">
                    <h3>Price Range</h3>
                    <div class="price-slider">
                        <input type="range" id="priceRange" min="0" max="5000" value="5000" onchange="updatePrice()">
                        <div class="price-display">
                            <span>₹0</span>
                            <span>₹<span id="priceValue">5000</span></span>
                        </div>
                    </div>
                </div>

                <!-- Additional Filters -->
                <div class="filter-section">
                    <h3>Amenities</h3>
                    <label style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; cursor: pointer;">
                        <input type="checkbox" id="wifi"> 
                        <span style="color: #475569;">WiFi</span>
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem; cursor: pointer;">
                        <input type="checkbox" id="charging"> 
                        <span style="color: #475569;">USB Charging</span>
                    </label>
                    <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                        <input type="checkbox" id="food"> 
                        <span style="color: #475569;">Food Service</span>
                    </label>
                </div>
            </aside>

            <!-- RESULTS AREA -->
            <div class="results-container">
                <!-- DATE SELECTOR -->
                <div class="date-selector">
                    <h3>Select Date</h3>
                    <div class="date-buttons" id="dateButtons">
                        <!-- Dates will be populated by JavaScript -->
                    </div>
                </div>

                <!-- BUS RESULTS -->
                <div id="busResults">
                    <div style="text-align: center; padding: 2rem; color: #475569;">
                        <p>Search for buses to see available options</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/script.js"></script>
</body>
</html>