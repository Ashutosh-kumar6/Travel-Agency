<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About - Travel Agency</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">✈️ TRAVEL AGENCY</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/destination">Destinations</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/food">Food</a></li>
                <li><a href="/rental">Rentals</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/bookYourTrip">Book Your Trip</a></li>
            </ul>
            <div class="auth-buttons">
                <a href="/login" class="btn btn-secondary">Login</a>
                <a href="/register" class="btn btn-primary">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- SEARCH BAR -->
    <div class="search-bar-wrapper">
        <div class="search-bar-container">
            <span class="search-icon">👥</span>
            <input type="text" class="search-input" placeholder="Learn about our team, awards, and achievements...">
            <button class="search-btn-icon">🔍</button>
        </div>
    </div>

    <!-- PAGE CONTENT -->
    <div class="page-container about-page">
        <h1 class="page-title">👑 About Travel Agency</h1>
        
        <div class="cards-grid">
            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1488646953014-85cb44e25828?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Our Story</h3>
                    <p>Founded in 2020, Travel Agency revolutionized luxury travel by combining cutting-edge technology with personalized service, serving elite travelers across 150+ destinations worldwide.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1567427018141-0584cfcbf1b8?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Award-Winning</h3>
                    <p>Multiple international awards for luxury travel excellence, customer satisfaction, and innovative travel solutions.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Global Presence</h3>
                    <p>24/7 multilingual support teams across 6 continents ensuring seamless travel experiences at any destination.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1552664730-d307ca884978?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Expert Team</h3>
                    <p>250+ travel experts with decades of combined experience in luxury hospitality and exclusive experiences.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Exclusive Network</h3>
                    <p>Partnerships with 5000+ luxury hotels, restaurants, and experience providers worldwide for unparalleled access.</p>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Commitment</h3>
                    <p>Dedicated to creating unforgettable moments and exceeding expectations on every journey.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>About Us</h4>
                <p>Luxury travel since 2020 with unmatched expertise.</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/destination">Destinations</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/about">About</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <ul>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <ul>
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">Instagram</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Travel Agency. All rights reserved.</p>
        </div>
    </footer>
    <script src="/script.js"></script>
</body>
</html>
