<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">✈️ TRAVEL AGENCY</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/destination">Destinations</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/food">Food</a></li>
                <li><a href="/rental">Rentals</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/bookYourTrip">Book Your Trip</a></li>
            </ul>
            <div class="auth-buttons">
                <a href="/login" class="btn btn-secondary">Login</a>
                <a href="/register" class="btn btn-primary">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <div class="page-container food-page">
        <h1 class="page-title">🍽️ Culinary Excellence</h1>
        
        <div class="cards-grid">
            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1565299624946-b28f40a0ca4b?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Italian Cuisine</h3>
                    <p>Authentic Michelin-starred Italian dining in Rome, Milan, and Venice with wine pairings.</p>
                    <div class="card-footer">
                        <span class="card-price">From $150</span>
                        <button class="card-button">Book</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1579584425555-c3ce17fd4351?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Japanese Omakase</h3>
                    <p>Exclusive chef's selection sushi experiences at Tokyo's finest establishments.</p>
                    <div class="card-footer">
                        <span class="card-price">From $200</span>
                        <button class="card-button">Book</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>French Haute Cuisine</h3>
                    <p>3-Michelin-star dining experiences in Paris and Lyon with sommelier guidance.</p>
                    <div class="card-footer">
                        <span class="card-price">From $250</span>
                        <button class="card-button">Book</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1559847844-5315695dadae?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Asian Fusion</h3>
                    <p>Modern fusion cuisine combining traditional Asian flavors with contemporary techniques.</p>
                    <div class="card-footer">
                        <span class="card-price">From $120</span>
                        <button class="card-button">Book</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1546833999-b9f581a1996d?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Premium Steakhouse</h3>
                    <p>World-class beef and fine dining experiences with private dining rooms.</p>
                    <div class="card-footer">
                        <span class="card-price">From $180</span>
                        <button class="card-button">Book</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1474722883778-792e7990302f?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Wine Tasting Tours</h3>
                    <p>Private vineyard tours in Bordeaux, Tuscany, and Napa Valley with expert sommeliers.</p>
                    <div class="card-footer">
                        <span class="card-price">From $300</span>
                        <button class="card-button">Book</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

