<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Destinations - Travel Agency</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">✈️ TRAVEL AGENCY</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/destination">Destinations</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/food">Food</a></li>
                <li><a href="/rental">Rentals</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/bookYourTrip">Book Your Trip</a></li>
            </ul>
            <div class="auth-buttons">
                <a href="/login" class="btn btn-secondary">Login</a>
                <a href="/register" class="btn btn-primary">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <div class="page-container destination-page">
        <h1 class="page-title">🌍 Explore World Destinations</h1>
        
        <div class="cards-grid">
            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Maldives</h3>
                    <p>Experience paradise with overwater bungalows, pristine beaches, and world-class diving.</p>
                    <div class="card-footer">
                        <span class="card-price">$2,999+</span>
                        <button class="card-button">Book Now</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1502602898536-47ad22581b52?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Paris, France</h3>
                    <p>The City of Light offers Michelin-starred dining, world-class museums, and romantic ambiance.</p>
                    <div class="card-footer">
                        <span class="card-price">$1,899+</span>
                        <button class="card-button">Book Now</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Swiss Alps</h3>
                    <p>Luxury mountain retreats with breathtaking views, skiing, and exclusive resorts.</p>
                    <div class="card-footer">
                        <span class="card-price">$2,499+</span>
                        <button class="card-button">Book Now</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1523906834658-6e24ef2386f9?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Italy</h3>
                    <p>Roman history, Renaissance art, and Italian cuisine in Venice, Rome, and Florence.</p>
                    <div class="card-footer">
                        <span class="card-price">$2,199+</span>
                        <button class="card-button">Book Now</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1490806843957-31f4c9a91c65?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Japan</h3>
                    <p>Ancient temples, modern cities, and culinary excellence from Tokyo to Kyoto.</p>
                    <div class="card-footer">
                        <span class="card-price">$2,399+</span>
                        <button class="card-button">Book Now</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-image" style="background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80');"></div>
                <div class="card-content">
                    <h3>Australia</h3>
                    <p>Great Barrier Reef, Sydney Opera House, and outback adventures await.</p>
                    <div class="card-footer">
                        <span class="card-price">$2,699+</span>
                        <button class="card-button">Book Now</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>About Us</h4>
                <p>Travel Agency brings you the finest travel experiences worldwide.</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/destination">Destinations</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/food">Food</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <ul>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <ul>
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">Instagram</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Travel Agency. All rights reserved.</p>
        </div>
    </footer>
    <script src="/script.js"></script>
</body>
</html>
