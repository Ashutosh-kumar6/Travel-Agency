<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Travel Agency</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">✈️ TRAVEL AGENCY</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/destination">Destinations</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/food">Food</a></li>
                <li><a href="/rental">Rentals</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/bookYourTrip">Book Your Trip</a></li>
            </ul>
        </div>
    </nav>

    <!-- PAGE CONTENT -->
    <div class="page-container login-page" style="display: flex; align-items: center; justify-content: center; min-height: 80vh;">
        <div class="card" style="max-width: 400px; width: 100%;">
            <div style="padding: 2rem;">
                <h1 style="text-align: center; color: var(--accent); margin-bottom: 2rem;">Welcome Back</h1>
                
                <form>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" placeholder="your@email.com" required>
                    </div>

                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" placeholder="••••••••" required>
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; color: var(--text-muted);">
                            <input type="checkbox" style="width: 18px; height: 18px; cursor: pointer;">
                            Remember me
                        </label>
                        <a href="#" style="color: var(--accent); text-decoration: none; font-size: 0.9rem;">Forgot?</a>
                    </div>

                    <button class="btn btn-primary btn-large" type="submit" style="width: 100%; margin-bottom: 1rem;">Login</button>

                    <p style="text-align: center; color: var(--text-muted);">
                        Don't have an account? <a href="/register" style="color: var(--accent); text-decoration: none; font-weight: 600;">Sign up</a>
                    </p>
                </form>

                <div style="margin-top: 2rem; border-top: 1px solid rgba(251, 191, 36, 0.1); padding-top: 1.5rem;">
                    <p style="text-align: center; color: var(--text-muted); margin-bottom: 1rem;">Or continue with</p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                        <button class="card-button" style="padding: 0.8rem;">Google</button>
                        <button class="card-button" style="padding: 0.8rem;">Apple</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-bottom" style="border-top: 1px solid rgba(251, 191, 36, 0.1); padding-top: 2rem;">
            <p>&copy; 2026 Travel Agency. All rights reserved.</p>
        </div>
    </footer>
    <script src="/script.js"></script>
</body>
</html>
