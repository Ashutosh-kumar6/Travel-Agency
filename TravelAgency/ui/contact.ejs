<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact - Travel Agency</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">✈️ TRAVEL AGENCY</div>
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/destination">Destinations</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/food">Food</a></li>
                <li><a href="/rental">Rentals</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact</a></li>
                <li><a href="/bookYourTrip">Book Your Trip</a></li>
            </ul>
            <div class="auth-buttons">
                <a href="/login" class="btn btn-secondary">Login</a>
                <a href="/register" class="btn btn-primary">Sign Up</a>
            </div>
        </div>
    </nav>

    <!-- SEARCH BAR -->
    <div class="search-bar-wrapper">
        <div class="search-bar-container">
            <span class="search-icon">📧</span>
            <input type="text" class="search-input" placeholder="Search support topics or FAQs...">
            <button class="search-btn-icon">🔍</button>
        </div>
    </div>

    <!-- PAGE CONTENT -->
    <div class="page-container contact-page">
        <h1 class="page-title">📞 Get In Touch</h1>
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-bottom: 3rem;">
            <div>
                <h2 style="color: var(--accent); margin-bottom: 1.5rem;">Send Us a Message</h2>
                <form>
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" placeholder="Your name" required>
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" placeholder="your@email.com" required>
                    </div>
                    <div class="form-group">
                        <label>Phone</label>
                        <input type="tel" placeholder="+1 (555) 000-0000" required>
                    </div>
                    <div class="form-group">
                        <label>Trip Date</label>
                        <input type="date" required>
                    </div>
                    <div class="form-group">
                        <label>Message</label>
                        <textarea placeholder="Tell us about your dream trip..." required></textarea>
                    </div>
                    <button class="btn btn-primary btn-large" type="submit">Send Message</button>
                </form>
            </div>

            <div>
                <h2 style="color: var(--accent); margin-bottom: 1.5rem;">Contact Information</h2>
                <div class="card">
                    <div class="card-content">
                        <h3>📍 Office Locations</h3>
                        <p><strong>New York</strong><br>123 Fifth Avenue, NYC<br>+1 (212) 555-1000</p>
                        <p><strong>London</strong><br>456 Park Lane, London<br>+44 (20) 7946-0958</p>
                        <p><strong>Dubai</strong><br>789 Emirates Hills<br>+971 (4) 4444-5555</p>
                    </div>
                </div>

                <div class="card" style="margin-top: 1rem;">
                    <div class="card-content">
                        <h3>🕐 Hours of Operation</h3>
                        <p>Monday - Friday: 8am - 8pm EST<br>
                        Saturday - Sunday: 10am - 6pm EST<br>
                        <strong>24/7 Emergency Support: +1 (888) LUXE-911</strong></p>
                    </div>
                </div>

                <div class="card" style="margin-top: 1rem;">
                    <div class="card-content">
                        <h3>📧 Email Support</h3>
                        <p>info@travelagency.com<br>
                        reservations@travelagency.com<br>
                        support@travelagency.com</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>About Us</h4>
                <p>Luxury travel expertise with global reach.</p>
            </div>
            <div class="footer-section">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/destination">Destinations</a></li>
                    <li><a href="/services">Services</a></li>
                    <li><a href="/contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Support</h4>
                <ul>
                    <li><a href="/about">About</a></li>
                    <li><a href="/contact">Contact Us</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h4>Follow Us</h4>
                <ul>
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">Instagram</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Travel Agency. All rights reserved.</p>
        </div>
    </footer>

    <style>
        @media (max-width: 768px) {
            div[style*="grid-template-columns: 1fr 1fr"] {
                grid-template-columns: 1fr !important;
            }
        }
    </style>
    <script src="/script.js"></script>
</body>
</html>
