<section class="search-bar-wrapper">
    <div class="search-bar-container">
        <span class="search-icon">Login</span>
        <input type="text" class="search-input" placeholder="Login to manage your bookings...">
        <button class="search-btn-icon" type="button">Go</button>
    </div>
</section>

<div class="page-container auth-page">
    <div class="auth-card card">
        <div class="card-content">
            <h1 class="page-title">Welcome Back</h1>
            <form action="/login" method="POST">
                <div class="form-group">
                    <label for="loginEmail">Email Address</label>
                    <input id="loginEmail" type="email" name="email" placeholder="your@email.com" required>
                </div>
                <div class="form-group">
                    <label for="loginPassword">Password</label>
                    <input id="loginPassword" type="password" name="password" placeholder="Enter your password" required>
                </div>
                <button class="btn btn-primary btn-large" type="submit">Login</button>
            </form>
            <p class="auth-switch">Don't have an account? <a href="/register">Create one here</a>.</p>
        </div>
    </div>
</div>
