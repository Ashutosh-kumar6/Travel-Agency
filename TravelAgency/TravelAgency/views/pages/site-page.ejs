<section class="search-bar-wrapper">
    <div class="search-bar-container">
        <span class="search-icon">Page</span>
        <input type="text" class="search-input" placeholder="<%= page.summary || 'Explore this page...' %>">
        <button class="search-btn-icon" type="button">Go</button>
    </div>
</section>

<div class="page-container">
    <div class="card detail-card">
        <div class="card-content">
            <h1 class="page-title"><%= page.heroTitle %></h1>
            <% if (page.summary) { %>
                <p class="helper-text"><%= page.summary %></p>
            <% } %>
            <div class="site-page-content">
                <% page.content.split('\n').forEach((paragraph) => { %>
                    <% if (paragraph.trim()) { %>
                        <p><%= paragraph %></p>
                    <% } %>
                <% }) %>
            </div>
        </div>
    </div>
</div>
