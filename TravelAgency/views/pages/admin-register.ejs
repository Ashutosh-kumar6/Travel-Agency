<div class="page-container auth-page admin-auth-page">
    <div class="auth-card card">
        <div class="card-content">
            <h1 class="page-title">Create Admin</h1>
            <form action="/admin/Ashu2406/create" method="POST">
                <div class="form-group">
                    <label for="adminName">Full Name</label>
                    <input id="adminName" type="text" name="name" required>
                </div>
                <div class="form-group">
                    <label for="adminRegisterEmail">Email</label>
                    <input id="adminRegisterEmail" type="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="adminRegisterPassword">Password</label>
                    <input id="adminRegisterPassword" type="password" name="password" required>
                </div>
                <div class="form-group">
                    <label for="adminConfirmPassword">Confirm Password</label>
                    <input id="adminConfirmPassword" type="password" name="confirmPassword" required>
                </div>
                <div class="form-group">
                    <label for="setupKey">Admin Setup Key</label>
                    <input id="setupKey" type="password" name="setupKey" placeholder="Default: travelagency-admin-key" required>
                </div>
                <button class="btn btn-primary btn-large" type="submit">Create Admin Account</button>
            </form>
            <p class="auth-switch">Already created one? <a href="/admin/Ashu2406/login">Go to admin login</a>.</p>
        </div>
    </div>
</div>
