<div class="admin-panel-page">
    <div class="admin-page-header">
        <h1>Edit Catalog Item</h1>
        <a href="/admin/Ashu2406/dashboard" class="btn btn-secondary">Back</a>
    </div>

    <div class="card">
        <div class="card-content">
            <form action="/admin/Ashu2406/items/<%= item._id %>?_method=PATCH" method="POST">
                <div class="content-grid compact-grid">
                    <div class="form-group">
                        <label for="itemSection">Section</label>
                        <select id="itemSection" name="section" required>
                            <option value="food" <%= item.section === 'food' ? 'selected' : '' %>>Food</option>
                            <option value="service" <%= item.section === 'service' ? 'selected' : '' %>>Service</option>
                            <option value="rental" <%= item.section === 'rental' ? 'selected' : '' %>>Rental</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="itemTitle">Title</label>
                        <input id="itemTitle" type="text" name="title" value="<%= item.title %>" required>
                    </div>
                    <div class="form-group">
                        <label for="itemPriceLabel">Price Label</label>
                        <input id="itemPriceLabel" type="text" name="priceLabel" value="<%= item.priceLabel %>">
                    </div>
                    <div class="form-group">
                        <label for="itemImage">Image URL</label>
                        <input id="itemImage" type="url" name="image" value="<%= item.image %>">
                    </div>
                </div>
                <div class="form-group">
                    <label for="itemDescription">Description</label>
                    <textarea id="itemDescription" name="description" required><%= item.description %></textarea>
                </div>
                <label class="admin-checkbox">
                    <input type="checkbox" name="isPublished" <%= item.isPublished ? 'checked' : '' %>>
                    <span>Published</span>
                </label>
                <button class="btn btn-primary" type="submit">Save Changes</button>
            </form>
        </div>
    </div>
</div>
